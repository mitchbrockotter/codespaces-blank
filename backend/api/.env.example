PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3001
JWT_SECRET=replace_me
COOKIE_NAME=pkba_session
DATABASE_URL=postgres://user:password@localhost:5432/pkba
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me
S3_BUCKET=pkba-reports
S3_FORCE_PATH_STYLE=false
DOWNLOAD_TOKEN_TTL_MINUTES=5
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
RATE_LIMIT_MAX=3
RATE_LIMIT_WINDOW_SECONDS=600

# Contact form email service
CONTACT_SMTP_HOST=smtp.office365.com
CONTACT_SMTP_PORT=587
CONTACT_SMTP_SECURE=false
CONTACT_SMTP_USER=replace_me
CONTACT_SMTP_PASS=replace_me
CONTACT_FROM_EMAIL=replace_me
CONTACT_RECIPIENT_EMAIL=pkbackendautomation@gmail.com
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX_REQUESTS=5
CONTACT_SMTP_CONNECTION_TIMEOUT_MS=10000
CONTACT_SMTP_GREETING_TIMEOUT_MS=10000
CONTACT_SMTP_SOCKET_TIMEOUT_MS=20000
CONTACT_SEND_TIMEOUT_MS=25000
CONTACT_SEND_CUSTOMER_CONFIRMATION=true
